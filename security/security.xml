<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Category for menu organization -->
        <record id="module_category_disciplinary" model="ir.module.category">
            <field name="name">Disciplinary</field>
            <field name="description">Manage employee disciplinary actions</field>
            <field name="sequence">20</field>
        </record>

        <!-- Manager Group -->
        <record id="group_disciplinary_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_disciplinary"/>
            <!-- Implies basic internal user -->
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- User Group -->
        <record id="group_disciplinary_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_disciplinary"/>
            <!-- Implies basic internal user -->
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Record Rules -->
        <!-- Employee can only see their own disciplinary actions -->
        <record id="rule_disciplinary_action_employee" model="ir.rule">
            <field name="name">Employee Disciplinary Actions</field>
            <field name="model_id" ref="model_hr_disciplinary_action"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Manager/HR User can see all disciplinary actions -->
        <record id="rule_disciplinary_action_hr_all" model="ir.rule">
            <field name="name">All Disciplinary Actions</field>
            <field name="model_id" ref="model_hr_disciplinary_action"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr_disciplinary_action.group_disciplinary_user')), (4, ref('hr_disciplinary_action.group_disciplinary_manager'))]"/>
        </record>
    </data>
</odoo>